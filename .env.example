
# Nebius Token Factory
NEBIUS_API_KEY=

# Notion
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Launch post URLs to scan (either or both)
X_POST_URL=
LINKEDIN_POST_URL=

# Paths to authenticated Playwright storageState files, captured once via
# `npm run capture-auth -- x ./secrets/x.storageState.json` (see README).
# In the Tenki sandbox these point at the read-only mounted volume instead,
# e.g. /workspace/secrets/x.storageState.json
X_STORAGE_STATE_PATH=./secrets/x.storageState.json
LINKEDIN_STORAGE_STATE_PATH=./secrets/linkedin.storageState.json
